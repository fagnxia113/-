											<gridcol  name="NCZJZF" caption="年初至今%" syscol="$ZAFYEAR"  visible="true" align="R"  headalign="R"  width="90" datatype="F" digital="2" clrtype="Z"  filter="0" ></gridcol>
										</gridcols>	
										<datasource  reqformat="1" masterid="4" name="pcwebcall_jjzt_jysjj_jjfl" body="002,,$$ZQDM$$"></datasource>
									</gridctrl>
								</component>
								<component caption="场内份额" id="7" name="splitpanel" >
