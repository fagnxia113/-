									<gridcol  name="ZSJC" caption="指数简称" syscol="$ZQJC" refzqdm="1" visible="true" align="L" headalign="L" width="90" datatype="S" clrtype="S"  filter="0" ></gridcol>
									<gridcol  name="ZSZF" caption="指数涨幅%" syscol="$ZAF" refzqdm="1" visible="true" align="R"   headalign="R" width="95" datatype="F" digital="2" clrtype="Z"  filter="0" ></gridcol>
								</gridcols>	
								<datasource  reqformat="1" treeid="2" name="pcwebcall_jjzt_jysjj_jjfl" body="001,$INBLOCK$,"></datasource>
							</gridctrl>
						</table>
						<table X="0" Y="-1" width="1" height="-1" isleaf="true"  hdirection="false" id="5"  name="tabpanel" >
