									<gridcol  name="JWRZF" caption="5日涨幅%"  visible="false" align="R"  headalign="R" width="90" datatype="F" digital="2"  formula="((1+JSRRZF/100)*(1+$ZAF/100)-1)*100" calccol="JSRRZF,$ZAF" clrtype="Z"  filter="0" ></gridcol>	
									<gridcol  name="JJRZF" caption="9日涨幅"  visible="false" align="R"  headalign="R" width="90" datatype="F" digital="2"  filter="0" ></gridcol>	
