						<datasource  reqformat="20" name="" body=""></datasource>
					</treepanel>
				</table>
				<table X="-1" Y="0" width="-1" height="1" isleaf="true"  hdirection="true" id="3"  name="splitpanel" >
					<splitpanel hdirection="true">
						<table X="0" Y="0" width="1" height="0.61" isleaf="true"  hdirection="true" id="4"  name="gridctrl" >
							<gridctrl>
								<gridcols fixednum="3" rowchgmsg="true" postslave="true" firstswitchzst="1" showtip="1"  defsort="$ZAF" expandfull="1" multibreed="2" >
									<gridcol  name="ZQDM" caption="基金代码" syscol="$ZQDM" refzqdm="0"  visible="true" align="L" headalign="L" width="75" datatype="S" clrtype="S" filter="0" ></gridcol>
									<gridcol  name="SC" caption="市场" syscol="$SC" refzqdm="0" visible="false" align="L"  headalign="L" width="60" datatype="S" clrtype="S" filter="0" ></gridcol>
									<gridcol  name="ZQJC" caption="基金简称" syscol="$ZQJC" refzqdm="0"  visible="true" align="L" headalign="L" width="160" datatype="S" clrtype="S"   filter="0" ></gridcol>
									<gridcol  name="$ZAF" caption="涨幅%" syscol="$ZAF" refzqdm="0"  visible="true" align="R"  headalign="R" width="65" datatype="F" digital="2" clrtype="Z"  filter="0" ></gridcol>
									<gridcol  name="$NOW" caption="现价" syscol="$NOW" refzqdm="0"  visible="true" align="R"  headalign="R"  width="75" datatype="F" digital="3"  filter="0" ></gridcol>						
									<gridcol  name="$JJJZ" caption="IOPV" syscol="$JJJZ" refzqdm="0"  visible="false" align="R"  headalign="R" width="60" datatype="F" digital="4"  filter="0" ></gridcol>
									<gridcol  name="YJL" caption="溢价率%"   visible="false" align="R"  width="80" datatype="F"  headalign="R" digital="2" clrtype="Z" formula="($NOW/$JJJZ-1)*100" calccol="$NOW,$JJJZ" > </gridcol>
									<gridcol  name="CJE" caption="成交额" syscol="$ZCJJE" refzqdm="0"  visible="true" align="R"  headalign="R" width="90" datatype="F" digital="2"  filter="0" ></gridcol>								
									<gridcol  name="JZRQ" caption="净值日期" visible="true" align="C"  headalign="C"  width="100" datatype="S"   filter="0" ></gridcol>
									<gridcol  name="DWJZ" caption="单位净值"  visible="true" align="R"  headalign="R" width="80" datatype="F" digital="4"  filter="0" ></gridcol>
									<gridcol  name="ZXFE" caption="最新份额" syscol="$J_LTGB" refzqdm="0"  visible="true" align="R"  headalign="R" width="90" datatype="F" fmttype="9" digital="1"  filter="0" ></gridcol>
									<gridcol  name="ZXGM" caption="最新规模"  visible="true" align="R"  headalign="R" width="85" datatype="F" digital="1" formula="$NOW*ZXFE" calccol="$NOW,ZXFE" fmttype="9" > </gridcol>
									<gridcol  name="ZXJYR" caption="最新交易日" visible="false" align="C"  headalign="C" width="90" datatype="D"  filter="0" ></gridcol>								
									<gridcol  name="ZAF3" caption="3日涨幅%" syscol="$ZAFPRE3" refzqdm="0"  visible="true" align="R"  headalign="R" width="90" datatype="F" digital="2"  filter="0" ></gridcol>
