													<xaxis name="JYRQ" caption="交易日期" datadesc="0"></xaxis>
													<yaxis fmttype="9" digital="2" rdigital="0"/>
												</properties>
												<datasource  reqformat="1"  masterid="4" name="pcwebcall_jjzt_etfjj_etffl" body="003,,$$ZQDM$$"></datasource>
