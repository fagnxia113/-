											<gridcol  name="SC" caption="市场" syscol="$SC"  visible="false" align="L" width="60" datatype="S" clrtype="S" filter="0" ></gridcol>
											<gridcol  name="ZQJC" caption="证券简称"   visible="true" align="L" headalign="L" width="80" datatype="S" clrtype="S" autosize="1"   filter="0" ></gridcol>
											<gridcol  name="ZAF" caption="涨幅%" syscol="$ZAF"  visible="true" align="R"  headalign="R"  width="70" datatype="F" digital="2" clrtype="Z"  filter="0" ></gridcol>
											<gridcol  name="NOW" caption="现价" syscol="$NOW"  visible="true" align="R"  headalign="R"  width="80" datatype="F" digital="3"   filter="0" ></gridcol>	
