											<gridctrl>
												<gridcols fixednum="3"  showtip="1" forbidmenu="0"  defsort="JYRQ"   >
													<gridcol  name="JYRQ" caption="截止日期" visible="true" align="C"  headalign="C" width="90" datatype="D"   filter="0" ></gridcol>
													<gridcol  name="ZXFE" caption="最新份额"  visible="true" align="R"  headalign="R" width="90" datatype="F" digital="2" fmttype="9"   filter="0" ></gridcol>
