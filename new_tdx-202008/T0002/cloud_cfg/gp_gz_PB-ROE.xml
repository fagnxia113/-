								<ctrls rowcount="1">
									<ctrl rowindex="0" index="1" text="?" tooltip="基于用户自行设定ROE取值范围及ROE垃圾股分割点，分别对ROE分割点两侧行业成分股的PB和ROE数据做简单线性回归，
得出线性回归斜率及线性回归截距，形成位于分割点左右两侧的两条线性回归方程式PB=β*ROE+α。通常情况下，
位于回归线下方属于PB估值未被高估的股票尚有价值发现的可能性，而位于回归线上方属于PB被高估或已被价值发现的股票，
此外，用户可以自行设定PB偏移值水平从而形成PB估值均衡带，来排除掉预期合理PB估值浮动区间内的个股。同时结合ROE水平，
帮助用户找到满足用户要求回报率水平的股票。       " type="static" hoffset="5" align="L" width="10"/>
									<ctrl rowindex="0" index="3" text="日期" type="date" width="140" bindparam="end_date">
										<datectrl change="0"/>
										<datevalue datetype="0" datespan="0" spantype="0"/>
									</ctrl>
									<ctrl rowindex="0" index="11" text="计算" type="button" hoffset="10" align="L" width="40" bindparam="IDOK">
										<button imageno="0"/>
									</ctrl>
									<ctrl rowindex="0" index="0" text="  回归线均衡带代表估值预期合理的区域，个股落在均衡带里意味着估值合理，落在均衡带之上是高估，落在之下是低估。默认ROE大于行业ROE中位数的股票属于价值投资的范畴，在PB-ROE估值模型中建议选择ROE大于行业ROE中位数的个股。" type="static" hoffset="5" align="L" width="1800" bindparam="CacheId">
										<edit change="0" defval="-1"/>
									</ctrl>
								</ctrls>
