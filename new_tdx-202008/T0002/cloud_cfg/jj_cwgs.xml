											<combox cbchange="1" defsel="0" remote="1" >
											    <remote textfld="CorpName" datafld="CorpID" >
											    	<extitem text="全部" value="0"/>
														<datasource reqformat="2" cache="0" keeporiginal="true" name="HQServ.hq_nlp" body="[{'ReqId': '500013','modname': 'mod_fuan.dll'}]" >
			    	    						</datasource>	
													</remote>
											</combox>
