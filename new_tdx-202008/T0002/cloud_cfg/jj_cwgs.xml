					<gridcol  name="FundSize" caption="最新份额" visible="true" align="R" headalign="R" width="80" fmttype="9" datatype="F" digital="2" autosize="1" fmtinvalid="1" clrtype="A" filter="0" ></gridcol>
					<gridcol  name="FundEstTime" caption="成立日期" visible="true" align="C" headalign="C" width="80" datatype="S"  autosize="1" fmtinvalid="1"  filter="0" ></gridcol>
