        	    </gridcols>
        	    <datasource reqformat="2" cache="0" keeporiginal="true" reqmaxcount="200" name="HQServ.hq_nlp_risk_return" condid="3" body="[{&quot;ReqId&quot;:&quot;500060&quot;,&quot;style_type&quot;:&quot;&quot;,&quot;style_details&quot;:&quot;$$style_details$$&quot;,&quot;company_id&quot;: &quot;&quot;,&quot;fund_size&quot;: &quot;$$fund_size$$&quot;,&quot;fund_setup_time&quot;: &quot;$$fund_setup_time$$&quot;,&quot;estimate_date&quot;: &quot;$$estimate_date$$&quot;,&quot;Sort&quot;:&quot;0&quot;,&quot;Desc&quot;:&quot;0&quot;,&quot;Page&quot;:&quot;$$$STARTPOS$ $$&quot;,&quot;PageSize&quot;:&quot;$$$PAGEROWS$ $$&quot;,&quot;modname&quot;:&quot;module_risk_return.dll&quot;}]"></datasource>	
